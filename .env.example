DISCORD_TOKEN=
CHANNEL_ID=
CHANNEL_ID_2=
SERVER_NAME=OKT HLL Server

# CRCON API base URL. It normally ends in /api/
# Example: https://crcon.example.org/api/
CRCON_API_URL=

# CRCON API key with permission to call get_team_view.
CRCON_API_KEY=

# Player flag used for the seeding bots.
BOT_FLAG=🌱

# Automatic geofence thresholds.
MIDCAP_BOT_THRESHOLD=35
LASTCAP_BOT_THRESHOLD=5

# The automation will not switch away from MIDCAP until it has seen at least
# this many flagged bots once. This prevents an immediate switch while the
# profiles are still joining the server.
BOT_COUNT_ARM_AT=36

# Number of consecutive measurements required before a switch.
BOT_COUNT_CONFIRMATIONS=3

# Polling and timeout settings in seconds.
BOT_COUNT_INTERVAL_SECONDS=5
CRCON_TIMEOUT_SECONDS=10
